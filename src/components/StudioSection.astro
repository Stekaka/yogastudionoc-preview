---
interface Props {
  eyebrow?: string;
  heading: string;
  paragraphs: string[];
  imageSrc: string;
  imageAlt: string;
  reverse?: boolean;
}

const { eyebrow, heading, paragraphs, imageSrc, imageAlt, reverse = false } =
  Astro.props as Props;
---

<section class="mx-auto w-full max-w-6xl px-4">
  <div
    class={`grid gap-10 items-center md:gap-14 ${
      reverse
        ? "md:grid-cols-[minmax(0,1fr)_minmax(0,1.15fr)]"
        : "md:grid-cols-[minmax(0,1.15fr)_minmax(0,1fr)]"
    }`}
  >
    <div class={reverse ? "md:order-2" : ""}>
      {eyebrow && (
        <p class="text-[0.7rem] tracking-[0.32em] uppercase text-[#2D2D2D]/60">
          {eyebrow}
        </p>
      )}
      <h2 class="mt-3 font-serif text-2xl sm:text-3xl text-[#2D2D2D]">
        {heading}
      </h2>
      <div class="mt-4 space-y-3 text-sm sm:text-base text-[#2D2D2D]/80 leading-relaxed">
        {paragraphs.map((p) => (
          <p>{p}</p>
        ))}
      </div>
    </div>

    <figure
      class={`relative overflow-hidden rounded-[2rem] border border-[#4A5D4E]/18 bg-white/60 shadow-[0_24px_90px_rgba(0,0,0,0.10)] ${
        reverse ? "md:order-1" : ""
      }`}
    >
      <img
        src={imageSrc}
        alt={imageAlt}
        loading="lazy"
        class="h-full w-full object-cover"
      />
      <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-black/12 via-transparent to-white/10" />
    </figure>
  </div>
</section>

