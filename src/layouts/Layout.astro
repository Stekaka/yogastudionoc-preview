---
import { ViewTransitions } from "astro:transitions";
import SEO from "../components/SEO.astro";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Yogastudion – En oas för harmoni och personlig utveckling.",
  description = "Yogastudion erbjuder Hatha, Vinyasa och Yin Yoga i hjärtat av Göteborg. Boka din nästa klass i en lugn, mjuk och minimalistisk miljö.",
} = Astro.props as Props;

const baseUrl = new URL(Astro.url).origin;
const logoImage = `${baseUrl}/images/recept/YogastudionLogo2.png`;
---

<!DOCTYPE html>
<html lang="sv" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#F5F2ED" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="sv_SE" />
    <meta property="og:image" content={logoImage} />

    <link rel="icon" href="/images/recept/YogastudionLogo2.png" type="image/png" />
    <link rel="apple-touch-icon" href="/images/recept/YogastudionLogo2.png" />

    <SEO
      businessName="Yogastudion"
      city="Göteborg"
      streetAddress="Vegagatan 12, Göteborg"
      postalCode="411 00"
      telephone="+46-31-000-00-00"
      url="https://yogastudion.com"
    />
    <ViewTransitions />
  </head>
  <body class="bg-[#F5F2ED] text-[#2D2D2D] antialiased font-sans">
    <div class="min-h-screen flex flex-col">
      <header class="w-full sticky top-0 z-40 pt-[env(safe-area-inset-top)] bg-[#F5F2ED]/10 backdrop-blur-lg shadow-[0_4px_12px_rgba(0,0,0,0.06)]">
        <div class="mx-auto w-full max-w-6xl px-4 py-4 flex items-center justify-between">
          <a
            href="/"
            class="flex items-center gap-2 group"
            aria-label="Till startsidan"
          >
            <div class="h-11 w-11 rounded-full overflow-hidden bg-transparent flex items-center justify-center">
              <img
                src="/images/recept/YogastudionLogo2.png"
                alt="Yogastudion logotyp"
                class="h-full w-full object-contain transition-transform duration-200 group-hover:scale-105"
                loading="eager"
                width="44"
                height="44"
              />
            </div>
            <span class="font-serif text-lg tracking-wide text-[#c8a96e] transition-colors">
              Yogastudion
            </span>
          </a>
          <nav class="hidden md:flex items-center gap-8 text-base font-medium tracking-wide">
            <a href="/kurser" class="text-[#2D2D2D] hover:text-[#c8a96e] transition-colors">
              Kurser
            </a>
            <a href="/utbildningar" class="text-[#2D2D2D] hover:text-[#c8a96e] transition-colors">
              Utbildningar
            </a>
            <a href="/om-oss" class="text-[#2D2D2D] hover:text-[#c8a96e] transition-colors">
              Våra lärare
            </a>
            <a href="/studion" class="text-[#2D2D2D] hover:text-[#c8a96e] transition-colors">
              Studion
            </a>
            <a href="/lar-dig-mer" class="text-[#2D2D2D] hover:text-[#c8a96e] transition-colors">
              Lär dig mer
            </a>
            <a href="/recept" class="text-[#2D2D2D] hover:text-[#c8a96e] transition-colors">
              Recept
            </a>
            <a href="/boka" class="text-[#2D2D2D] hover:text-[#c8a96e] transition-colors">
              Boka
            </a>
          </nav>
          <button
            id="ys-mobile-menu-btn"
            type="button"
            class="ys-mobile-menu-btn md:hidden inline-flex items-center justify-center h-11 w-11 rounded-full bg-[#F5F2ED]/30 hover:bg-[#F5F2ED]/55 backdrop-blur-lg shadow-[0_6px_18px_rgba(0,0,0,0.08)] ring-1 ring-black/5 transition relative"
            aria-label="Öppna meny"
            aria-controls="ys-mobile-menu"
            aria-expanded="false"
          >
            <svg
              class="ys-menu-icon ys-menu-icon--hamburger"
              width="22"
              height="22"
              viewBox="0 0 24 24"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
              aria-hidden="true"
            >
              <path d="M4 7H20" stroke="#2D2D2D" stroke-width="1.8" stroke-linecap="round" />
              <path d="M4 12H20" stroke="#2D2D2D" stroke-width="1.8" stroke-linecap="round" />
              <path d="M4 17H20" stroke="#2D2D2D" stroke-width="1.8" stroke-linecap="round" />
            </svg>
            <svg
              class="ys-menu-icon ys-menu-icon--close absolute"
              width="22"
              height="22"
              viewBox="0 0 24 24"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
              aria-hidden="true"
            >
              <path d="M6 6L18 18" stroke="#2D2D2D" stroke-width="1.8" stroke-linecap="round" />
              <path d="M18 6L6 18" stroke="#2D2D2D" stroke-width="1.8" stroke-linecap="round" />
            </svg>
          </button>
        </div>

        <div id="ys-mobile-menu" class="md:hidden ys-mobile-menu" data-open="false">
          <button
            type="button"
            data-ys-mobile-overlay
            class="fixed left-0 right-0 bottom-0 z-[45] bg-black/50 backdrop-blur-sm cursor-pointer border-0 p-0 m-0 w-full"
            style="top: var(--ys-mobile-header-height, 4rem); height: calc(100dvh - var(--ys-mobile-header-height, 4rem));"
            aria-label="Stäng meny (klicka utanför menyn)"
          />
          <div
            role="dialog"
            aria-modal="true"
            aria-label="Meny"
            id="ys-mobile-menu-panel"
            class="fixed right-0 z-50 w-[19rem] max-w-[86vw] ys-mobile-menu-panel"
            style="top: var(--ys-mobile-header-height, 4rem); height: calc(100dvh - var(--ys-mobile-header-height, 4rem)); max-height: calc(100dvh - var(--ys-mobile-header-height, 4rem));"
          >
            <nav class="px-5 pt-5 pb-5 overflow-y-auto">
              <ul class="flex flex-col gap-0.5 text-base font-medium tracking-wide">
                <li><a href="/kurser" class="block px-3 py-3 rounded-xl text-[#2D2D2D] hover:bg-black/5 hover:text-[#c8a96e] transition-colors">Kurser</a></li>
                <li><a href="/utbildningar" class="block px-3 py-3 rounded-xl text-[#2D2D2D] hover:bg-black/5 hover:text-[#c8a96e] transition-colors">Utbildningar</a></li>
                <li><a href="/om-oss" class="block px-3 py-3 rounded-xl text-[#2D2D2D] hover:bg-black/5 hover:text-[#c8a96e] transition-colors">Våra lärare</a></li>
                <li><a href="/studion" class="block px-3 py-3 rounded-xl text-[#2D2D2D] hover:bg-black/5 hover:text-[#c8a96e] transition-colors">Studion</a></li>
                <li><a href="/lar-dig-mer" class="block px-3 py-3 rounded-xl text-[#2D2D2D] hover:bg-black/5 hover:text-[#c8a96e] transition-colors">Lär dig mer</a></li>
                <li><a href="/recept" class="block px-3 py-3 rounded-xl text-[#2D2D2D] hover:bg-black/5 hover:text-[#c8a96e] transition-colors">Recept</a></li>
                <li><a href="/boka" class="block px-3 py-3 rounded-xl text-[#2D2D2D] hover:bg-black/5 hover:text-[#c8a96e] transition-colors">Boka</a></li>
              </ul>
            </nav>
          </div>
        </div>
      </header>

      <main class="flex-1">
        <slot />
      </main>

      <footer class="border-t border-black/5 mt-16">
        <div class="mx-auto w-full max-w-6xl px-4 py-8 text-sm text-[#2D2D2D]/70 flex flex-col md:flex-row md:items-center md:justify-between gap-4">
          <a href="/" class="flex items-center gap-4 group w-fit">
            <img
              src="/images/recept/YogastudionLogo2.png"
              alt=""
              class="h-20 w-20 md:h-28 md:w-28 shrink-0 object-contain transition-colors"
              width="80"
              height="80"
              loading="lazy"
            />
            <div>
              <p class="font-serif text-xl md:text-2xl text-[#2D2D2D]/90 group-hover:text-[#c8a96e] transition-colors">Yogastudion</p>
              <p class="text-sm md:text-base">Yoga i Göteborg</p>
            </div>
          </a>
          <div class="space-y-1">
            <p>Vegagatan 16, 413 09 Göteborg</p>
            <p>Tel: <a href="tel:+46734444244" class="underline hover:text-[#c8a96e]">0734444244</a> · E-post: <a href="mailto:hej@yogastudion.com" class="underline hover:text-[#c8a96e]">hej@yogastudion.com</a></p>
          </div>
        </div>
      </footer>
    </div>
    <script type="module" src="/src/components/ui-loader.js"></script>
    <script>
      function clearKurserNavState() {
        if (!window.location.pathname.startsWith("/kurser")) {
          document.body.classList.remove("ys-header-extended", "ys-glass-visible", "ys-detaching");
          document.body.style.removeProperty("--ys-sticky-height");
          document.body.style.removeProperty("--ys-nav-height");
        }
      }
      clearKurserNavState();
      document.addEventListener("astro:page-load", clearKurserNavState);
    </script>
    <script>
      function initMobileMenu() {
        const btn = document.getElementById("ys-mobile-menu-btn");
        const menu = document.getElementById("ys-mobile-menu");
        const header = document.querySelector("header");
        if (!btn || !menu) return;
        if (btn.dataset.ysMobileMenuBound === "1") return;
        btn.dataset.ysMobileMenuBound = "1";

        const overlay = menu.querySelector("[data-ys-mobile-overlay]");

        const setOpen = (open) => {
          if (open && header) {
            document.documentElement.style.setProperty("--ys-mobile-header-height", `${header.offsetHeight}px`);
          } else {
            document.documentElement.style.removeProperty("--ys-mobile-header-height");
          }
          menu.dataset.open = open ? "true" : "false";
          btn.setAttribute("aria-expanded", open ? "true" : "false");
          btn.setAttribute("aria-label", open ? "Stäng meny" : "Öppna meny");
          btn.classList.toggle("ys-menu-open", open);
          menu.setAttribute("aria-hidden", open ? "false" : "true");
          if (open) {
            document.body.classList.add("overflow-hidden");
          } else {
            setTimeout(() => document.body.classList.remove("overflow-hidden"), 320);
          }
        };

        const toggle = () => setOpen(menu.dataset.open !== "true");
        const close = () => setOpen(false);

        btn.addEventListener("click", toggle);
        overlay?.addEventListener("click", close);

        menu.querySelectorAll("a[href]").forEach((a) => a.addEventListener("click", close));

        document.addEventListener("keydown", (e) => {
          if (e.key === "Escape") close();
        });

        // Ensure it closes on route changes (ViewTransitions / SPA-ish nav)
        document.addEventListener("astro:before-swap", close);
      }

      document.addEventListener("astro:page-load", initMobileMenu);
    </script>
  </body>
</html>

