---
import Layout from "../layouts/Layout.astro";
import TeacherGallery from "../components/TeacherGallery";

const title = "Våra lärare – Yogastudion";
const description =
  "Lär känna yogalärarna på Yogastudion i Göteborg. Välkommen till en praktik med värme, tydlighet och möjlighet att anpassa efter dig.";
---

<Layout title={title} description={description}>
  <main class="mx-auto w-full max-w-6xl px-4 py-10 sm:py-14">
    <div class="mx-auto w-full max-w-6xl px-0 sm:px-0">
      <TeacherGallery client:load />
    </div>
  </main>
</Layout>
