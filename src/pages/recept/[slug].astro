---
import Layout from "../../layouts/Layout.astro";
import { getRecipeBySlug, getRecipeSlugs } from "../../data/recipes";

export function getStaticPaths() {
  return getRecipeSlugs().map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const recipe = slug ? getRecipeBySlug(slug) : undefined;

if (!recipe) {
  return Astro.redirect("/recept");
}

const title = `${recipe.title} – Recept | Yogastudion Göteborg`;
const description =
  recipe.excerpt.length > 155 ? recipe.excerpt.slice(0, 155) + "…" : recipe.excerpt;

const dateFormatted = new Date(recipe.date).toLocaleDateString("sv-SE", {
  day: "numeric",
  month: "long",
  year: "numeric",
});
---

<Layout title={title} description={description}>
  <main class="mx-auto w-full max-w-3xl px-4 py-10 sm:py-14">
    <nav aria-label="Brödsmulor" class="mb-8">
      <ol class="flex flex-wrap items-center gap-2 text-sm text-[#2D2D2D]/70">
        <li><a href="/" class="hover:text-[#4A5D4E]">Startsida</a></li>
        <li aria-hidden="true">/</li>
        <li><a href="/recept" class="hover:text-[#4A5D4E]">Recept</a></li>
        <li aria-hidden="true">/</li>
        <li class="text-[#2D2D2D]" aria-current="page">{recipe.title}</li>
      </ol>
    </nav>

    <header class="mb-10">
      {recipe.category && (
        <p class="text-xs font-medium uppercase tracking-[0.16em] text-[#4A5D4E]">
          {recipe.category}
        </p>
      )}
      <h1 class="mt-2 font-serif text-3xl sm:text-4xl text-[#2D2D2D]">
        {recipe.title}
      </h1>
      <p class="mt-3 text-sm text-[#2D2D2D]/60">
        {recipe.author} · {dateFormatted}
      </p>
      {recipe.image && (
        <figure class="mt-6 rounded-2xl overflow-hidden border border-[#4A5D4E]/10 aspect-[16/10] bg-[#2D2D2D]/5">
          <img
            src={recipe.image}
            alt={`${recipe.title} – receptbild`}
            class="h-full w-full object-cover"
            width="800"
            height="500"
            loading="eager"
            fetchpriority="high"
          />
        </figure>
      )}
    </header>

    <div class="recipe-body space-y-10">
      <section aria-labelledby="ingredients-heading" class="rounded-2xl border border-[#4A5D4E]/15 bg-white/60 p-6">
        <h2 id="ingredients-heading" class="font-serif text-xl text-[#2D2D2D] mt-0 mb-4">
          Ingredienser
        </h2>
        <ul class="list-none pl-0 space-y-2 text-[#2D2D2D]/90">
          {recipe.ingredients.map((item) => (
            <li class="flex gap-3">
              <span class="text-[#4A5D4E] shrink-0" aria-hidden="true">·</span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </section>

      <section aria-labelledby="instructions-heading">
        <h2 id="instructions-heading" class="font-serif text-xl text-[#2D2D2D] mb-4">
          Gör så här
        </h2>
        <ol class="list-none pl-0 space-y-6">
          {recipe.instructions.map((step, i) => (
            <li class="flex gap-4">
              <span
                class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-[#4A5D4E]/15 text-sm font-semibold text-[#4A5D4E]"
                aria-hidden="true"
              >
                {i + 1}
              </span>
              <p class="pt-0.5 text-[#2D2D2D]/90 leading-relaxed">{step}</p>
            </li>
          ))}
        </ol>
      </section>

      {recipe.tips && recipe.tips.length > 0 && (
        <section class="rounded-2xl border border-[#4A5D4E]/15 bg-[#4A5D4E]/5 p-5 sm:p-6">
          <h2 class="font-serif text-lg text-[#2D2D2D] mt-0 mb-3">Tips</h2>
          <ul class="list-none pl-0 space-y-2 text-sm text-[#2D2D2D]/85">
            {recipe.tips.map((tip) => (
              <li class="flex gap-2">
                <span class="text-[#4A5D4E]" aria-hidden="true">→</span>
                <span>{tip}</span>
              </li>
            ))}
          </ul>
        </section>
      )}

      {recipe.benefits && (
        <section class="rounded-2xl border border-amber-200/50 bg-amber-50/40 p-5 sm:p-6">
          <h2 class="font-serif text-lg text-[#2D2D2D] mt-0 mb-3">Varför denna rätt</h2>
          <p class="text-[#2D2D2D]/90 text-sm sm:text-base leading-relaxed mb-0">
            {recipe.benefits}
          </p>
        </section>
      )}

      {recipe.ingredientBenefits && recipe.ingredientBenefits.length > 0 && (
        <section class="rounded-2xl border border-[#4A5D4E]/10 bg-white/40 p-5 sm:p-6">
          <h2 class="font-serif text-lg text-[#2D2D2D] mt-0 mb-4">Ingrediensernas effekter</h2>
          <ul class="space-y-3">
            {recipe.ingredientBenefits.map(({ name, text }) => (
              <li>
                <span class="font-medium text-[#2D2D2D]">{name}.</span>
                <span class="text-[#2D2D2D]/80 text-sm"> {text}</span>
              </li>
            ))}
          </ul>
        </section>
      )}

      {recipe.notePregnant && (
        <section class="rounded-2xl border border-amber-200/60 bg-amber-50/50 p-5 sm:p-6">
          <h2 class="font-serif text-lg text-[#2D2D2D] mt-0 mb-3">Gravid eller ammar?</h2>
          <p class="text-[#2D2D2D]/90 text-sm sm:text-base leading-relaxed mb-0">
            {recipe.notePregnant}
          </p>
        </section>
      )}

      <section class="pt-6 border-t border-[#4A5D4E]/15">
        <p class="text-[#2D2D2D]/70 text-sm">
          Fler recept och inspiration hittar du under <a href="/recept" class="text-[#4A5D4E] hover:underline">Recept</a>.
          Vill du öva yoga i Göteborg? Boka din plats via <a href="/boka" class="text-[#4A5D4E] hover:underline">Boka</a>.
        </p>
      </section>
    </div>

    <footer class="mt-12 pt-6">
      <a
        href="/recept"
        class="inline-flex items-center text-sm font-medium text-[#4A5D4E] hover:text-[#2D2D2D]"
      >
        <span aria-hidden="true" class="mr-2">←</span>
        Tillbaka till alla recept
      </a>
    </footer>
  </main>
</Layout>
