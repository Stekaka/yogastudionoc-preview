---
import Layout from "../layouts/Layout.astro";
import WeeklySchedule from "../components/WeeklySchedule";
import BookingForm from "../components/BookingForm";

const title = "Schema & bokning – Yogastudion Göteborg";
const description =
  "Se veckans schema och boka yoga på Yogastudion i Göteborg. Välj klass, lärare och skicka en bokningsförfrågan.";
---

<Layout title={title} description={description}>
  <main class="mx-auto w-full max-w-6xl px-4 py-10 sm:py-14 space-y-10">
    <section class="space-y-3 max-w-3xl">
      <p class="text-[0.7rem] tracking-[0.32em] uppercase text-[#2D2D2D]/60">
        Schema · Boka yoga
      </p>
      <h1 class="font-serif text-3xl sm:text-4xl text-[#2D2D2D]">
        Schema & bokning
      </h1>
      <p class="text-sm sm:text-base text-[#2D2D2D]/80 leading-relaxed">
        Välj en klass i schemat eller kom hit via en lärare – då förifyller vi bokningen så
        du kan skicka en lugn förfrågan.
      </p>
    </section>

    <section id="boka" class="space-y-6">
      <WeeklySchedule client:load />

      <div class="grid gap-6 lg:grid-cols-[minmax(0,1fr)_minmax(0,0.9fr)] items-start">
        <div class="rounded-3xl border border-[#4A5D4E]/12 bg-white/70 backdrop-blur-md shadow-[0_22px_80px_rgba(0,0,0,0.10)] p-6 sm:p-7">
          <h2 class="font-serif text-xl sm:text-2xl text-[#2D2D2D]">
            Skicka bokningsförfrågan
          </h2>
          <p class="mt-2 text-sm text-[#2D2D2D]/75 leading-relaxed">
            Välj lärare och önskat datum. Vi återkommer med bekräftelse och detaljer.
          </p>
          <div class="mt-5">
            <BookingForm client:load />
          </div>
        </div>

        <aside class="rounded-3xl border border-[#4A5D4E]/12 bg-[#F5F2ED] p-6 sm:p-7">
          <p class="text-[0.7rem] tracking-[0.32em] uppercase text-[#2D2D2D]/60">
            Tips
          </p>
          <p class="mt-3 text-sm text-[#2D2D2D]/80 leading-relaxed">
            Om du kommer från en lärarprofil försöker vi förifylla läraren automatiskt.
            Du kan alltid ändra i listan.
          </p>
        </aside>
      </div>
    </section>
  </main>

  <script is:inline>
    (() => {
      const params = new URLSearchParams(window.location.search);
      const teacher = params.get("teacher");
      if (!teacher) return;

      const run = () => {
        window.dispatchEvent(
          new CustomEvent("booking:select", {
            detail: { teacher },
          })
        );
        const bookingEl = document.getElementById("boka");
        bookingEl?.scrollIntoView({ behavior: "smooth", block: "start" });
      };

      // Give React islands a moment to hydrate
      window.setTimeout(run, 450);
    })();
  </script>
</Layout>

