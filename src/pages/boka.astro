---
import Layout from "../layouts/Layout.astro";
import WeeklySchedule from "../components/WeeklySchedule";
---

<Layout
  title="Boka | Yogastudion"
  description="Boka ditt yogapass på Yogastudion i Göteborg. Välj klass i veckoschemat och skicka en förfrågan till läraren."
>
  <div class="bg-transparent min-h-screen">
    <!-- Hero – tydlig bokningsintro -->
    <section class="mx-auto max-w-6xl px-4 pt-10 pb-6 md:pt-14 md:pb-8">
      <h1 class="font-serif text-3xl font-semibold text-[#2D2D2D] md:text-4xl">
        Boka
      </h1>
      <p class="mt-2 max-w-xl text-[#2D2D2D]/75 text-base">
        Välj vecka och pass i schemat nedan, klicka på en klass och sedan Boka plats. Du skickar en förfrågan till läraren – vi återkommer med bekräftelse.
      </p>
    </section>

    <!-- Veckoschema (samma som startsidan, utan egen rubriktext här) -->
    <WeeklySchedule client:load transparentBackground compactHeading />

    <!-- Kontakt -->
    <section class="mx-auto max-w-6xl px-4 pb-20 md:pb-28" aria-labelledby="boka-kontakt-heading">
      <div class="rounded-2xl border border-black/5 bg-white/90 p-6 md:p-8 shadow-[0_4px_24px_rgba(0,0,0,0.04)] max-w-2xl">
        <h2 id="boka-kontakt-heading" class="font-serif text-xl font-semibold text-[#2D2D2D] mb-2">
          Kontakt
        </h2>
        <p class="text-sm text-[#2D2D2D]/70 mb-4">
          Frågor om bokning eller klasser? Hör av er.
        </p>
        <div class="flex flex-col gap-2 text-sm text-[#2D2D2D]/90">
          <p>Vegagatan 16, 413 09 Göteborg</p>
          <p>
            <a href="tel:+46734444244" class="underline decoration-[#c8a96e]/55 underline-offset-2 hover:text-[#c8a96e] hover:decoration-[#c8a96e] transition-colors">0734444244</a>
          </p>
          <p>
            <a href="mailto:hej@yogastudion.com" class="underline decoration-[#c8a96e]/55 underline-offset-2 hover:text-[#c8a96e] hover:decoration-[#c8a96e] transition-colors">hej@yogastudion.com</a>
          </p>
        </div>
      </div>
    </section>
  </div>
</Layout>
